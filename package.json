{
  "name": "kodechirp",
  "version": "2.0.0",
  "private": true,
  "description": "KodeChirp — Production-grade peer-learning coding platform",
  "scripts": {
    "dev": "docker compose up",
    "dev:gateway": "cd gateway && npm run dev",
    "dev:worker": "cd workers && uvicorn src.main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "cd gateway && npm install && cd ../frontend && npm install",
    "build:sandboxes": "bash scripts/build-sandboxes.sh",
    "init:db": "bash scripts/init-db.sh",
    "setup": "bash scripts/dev-setup.sh",
    "health": "bash scripts/health-check.sh",
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "logs": "docker compose logs -f",
    "logs:gateway": "docker compose logs -f gateway",
    "logs:worker": "docker compose logs -f worker"
  }
}
