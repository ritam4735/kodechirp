# ─── KodeChirp Environment Configuration ─────────────────────────────────────
# Copy this to .env and fill in production values

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://kodechirp:${POSTGRES_PASSWORD}@postgres:5432/kodechirp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT Secrets ───────────────────────────────────────────────────────────────
JWT_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars

# ── Gateway ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4
EXECUTION_TIMEOUT=10
MAX_RETRIES=3

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
